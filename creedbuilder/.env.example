# Copied to .env by the one-click installer. Never commit .env.

PORT=8787
WEBHOOK_SECRET=change-me

# true = quote only, no on-chain tx (safe default)
DRY_RUN=true

# Solana RPC (public default; replace with Helius/QuickNode for reliability)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Base58 secret key (64-byte keypair). Generated by installer if missing.
SOLANA_PRIVATE_KEY=

# Jupiter: leave empty to use free lite-api.jup.ag; set key for api.jup.ag
JUPITER_API_KEY=

# Swap route mints
# SOL wrapped mint
SOL_MINT=So11111111111111111111111111111111111111112
# Token to buy with SOL / sell back to SOL (default USDC)
TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# BUY spends this much SOL (lamports: 0.01 SOL = 10000000)
BUY_AMOUNT_LAMPORTS=10000000

# SELL spends this % of TOKEN balance (1-100)
SELL_PERCENT=100

SLIPPAGE_BPS=50
