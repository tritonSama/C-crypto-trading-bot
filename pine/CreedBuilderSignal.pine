//@version=5
indicator("creedBuilder Signal (Supertrend)", overlay=true, max_labels_count=500)

// TradingView cannot talk to Jupiter directly.
// Create an alert on this script and set the webhook URL from Start.cmd / start.sh.
// Alert message must be exact JSON (see below).

atrPeriod = input.int(10, "ATR Length", minval=1)
factor = input.float(3.0, "Supertrend Factor", minval=0.1, step=0.1)
src = input.source(hl2, "Source")

[supertrend, direction] = ta.supertrend(factor, atrPeriod)

plot(supertrend, "Supertrend", color=direction < 0 ? color.new(color.green, 0) : color.new(color.red, 0))

buySignal = ta.change(direction) < 0
sellSignal = ta.change(direction) > 0

plotshape(buySignal, title="Buy", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), text="BUY", textcolor=color.white, size=size.tiny)
plotshape(sellSignal, title="Sell", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="SELL", textcolor=color.white, size=size.tiny)

// --- Alerts ---
// In TradingView Alert:
//   Webhook URL: https://<tunnel>/webhook
//   Message for BUY:
//     {"secret":"REPLACE_WITH_WEBHOOK_SECRET","action":"buy"}
//   Message for SELL:
//     {"secret":"REPLACE_WITH_WEBHOOK_SECRET","action":"sell"}

alertcondition(buySignal, title="creedBuilder Buy", message='{"secret":"REPLACE_WITH_WEBHOOK_SECRET","action":"buy"}')
alertcondition(sellSignal, title="creedBuilder Sell", message='{"secret":"REPLACE_WITH_WEBHOOK_SECRET","action":"sell"}')
